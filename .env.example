# ─────────────────────────────────────────────────────────────────────────────
# DocQA — Environment Variables
# Copy this file to .env and fill in your values before running docker-compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=DocQA
DEBUG=false
MAX_UPLOAD_SIZE_MB=50

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=docqa_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=docqa
DATABASE_URL=postgresql://docqa_user:your_secure_password_here@postgres:5432/docqa

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required: your OpenAI API key
OPENAI_API_KEY=your_openai_or_openrouter_api_key_here
OPENAI_MODEL=gpt-4o-mini
# Optional: OpenAI-compatible base URL (e.g., https://openrouter.ai/api/v1)
OPENAI_BASE_URL=
# Optional: sent as HTTP-Referer header for OpenRouter ranking
OPENAI_HTTP_REFERER=
# Optional: sent as X-OpenRouter-Title header for OpenRouter ranking
OPENAI_APP_TITLE=
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.1

# ── Storage paths (inside Docker, these map to named volumes) ─────────────────
UPLOAD_DIR=/data/uploads
INDEX_DIR=/data/indices

# ── Chunking ──────────────────────────────────────────────────────────────────
# Characters per chunk. 800 chars ≈ ~150 tokens — fits comfortably in context
# while keeping chunks semantically focused.
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Number of chunks to retrieve per question
RETRIEVAL_TOP_K=5
# Cosine similarity threshold (0–1). Chunks below this are considered irrelevant.
RETRIEVAL_SCORE_THRESHOLD=0.12

# ── Conversation ──────────────────────────────────────────────────────────────
# Maximum number of prior turn-pairs included in the LLM prompt
MAX_HISTORY_TURNS=5

# ── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
